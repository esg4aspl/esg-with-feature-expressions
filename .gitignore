!files/Cases/

# ...BUT ignore these generated folders/files INSIDE every Case folder
files/Cases/*/comparativeEfficiencyTestPipeline/
files/Cases/*/DOTs/
files/Cases/*/EFGs/
files/Cases/*/extremeScalabilityTestPipeline
files/Cases/*/faultdetection/
files/Cases/*/productConfigurations/
files/Cases/*/testsequenceanalysis/
files/Cases/*/testsequences/

# Ignore the generated configurations text file for every case
files/Cases/*/*_ProductConfigurations.txt
*.zip
