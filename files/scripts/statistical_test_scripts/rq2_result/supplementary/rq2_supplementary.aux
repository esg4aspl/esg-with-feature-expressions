\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces S5: Pairwise Wilcoxon signed-rank results on the 80 paired shards per (SPL, level pairing, metric). MO denotes \textit  {Model Once, Generate Any}, Struct the structural baseline, and Stoch the stochastic baseline. The reported $A_{12}$ is the Vargha--Delaney effect size (approach A vs.~approach B; values close to 1 favour A, values close to 0 favour B). $p_{\mathit  {BH}}$ is the Benjamini--Hochberg corrected $p$-value at $\alpha = 0.05$; cells flagged $^{\mathrm  {ns}}$ are not significant after correction.}}{4}{table.5}\protected@file@percent }
\newlabel{tab:rq2-supp-S5}{{5}{4}{S5: Pairwise Wilcoxon signed-rank results on the 80 paired shards per (SPL, level pairing, metric). MO denotes \textit {Model Once, Generate Any}, Struct the structural baseline, and Stoch the stochastic baseline. The reported $A_{12}$ is the Vargha--Delaney effect size (approach A vs.~approach B; values close to 1 favour A, values close to 0 favour B). $p_{\mathit {BH}}$ is the Benjamini--Hochberg corrected $p$-value at $\alpha = 0.05$; cells flagged $^{\mathrm {ns}}$ are not significant after correction}{table.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces S6: Per-cell run-to-run stability summary for all 256 (SPL, approach, coverage level, metric) cells. The coefficient of variation $\mathrm  {CV}\% = 100 \cdot \mathrm  {std}/\mathrm  {mean}$ is computed across runs of each shard, then aggregated to the median (column \emph  {Median CV}) and maximum (column \emph  {Max CV}) across the 80 shards. Stability bands: \emph  {very stable} when median CV $< 5\%$, \emph  {stable} between $5\%$ and $10\%$, \emph  {notable variance} above $10\%$ (Section~\ref {sec:rq2_stability}).}}{5}{table.6}\protected@file@percent }
\newlabel{tab:rq2-supp-S6}{{6}{5}{S6: Per-cell run-to-run stability summary for all 256 (SPL, approach, coverage level, metric) cells. The coefficient of variation $\mathrm {CV}\% = 100 \cdot \mathrm {std}/\mathrm {mean}$ is computed across runs of each shard, then aggregated to the median (column \emph {Median CV}) and maximum (column \emph {Max CV}) across the 80 shards. Stability bands: \emph {very stable} when median CV $< 5\%$, \emph {stable} between $5\%$ and $10\%$, \emph {notable variance} above $10\%$ (Section~\ref {sec:rq2_stability})}{table.6}{}}
\@writefile{lot}{\contentsline {table}{\numberline {8}{\ignorespaces S7: Top 50 cells with the highest median coefficient of variation across the 80 shards. The small and medium-sized SPLs dominate this ranking because their absolute timing values are small (milliseconds per shard), so a few milliseconds of JVM jitter inflates the relative spread. The same effect was discussed for RQ1 in Section~\ref {sec:rq1_stability}.}}{6}{table.8}\protected@file@percent }
\newlabel{tab:rq2-supp-S7}{{8}{6}{S7: Top 50 cells with the highest median coefficient of variation across the 80 shards. The small and medium-sized SPLs dominate this ranking because their absolute timing values are small (milliseconds per shard), so a few milliseconds of JVM jitter inflates the relative spread. The same effect was discussed for RQ1 in Section~\ref {sec:rq1_stability}}{table.8}{}}
\@writefile{lot}{\contentsline {table}{\numberline {9}{\ignorespaces S8: Per-shard median peak heap memory (MB) during test generation, across all SPLs, approaches, and coverage levels. The article main text (Section~\ref {sec:rq2_pairwise}) cites only the syngo.via and Hockerty Shirts values at $L = 2$; this table gives the complete set.}}{7}{table.9}\protected@file@percent }
\newlabel{tab:rq2-supp-S8}{{9}{7}{S8: Per-shard median peak heap memory (MB) during test generation, across all SPLs, approaches, and coverage levels. The article main text (Section~\ref {sec:rq2_pairwise}) cites only the syngo.via and Hockerty Shirts values at $L = 2$; this table gives the complete set}{table.9}{}}
\@writefile{lot}{\contentsline {table}{\numberline {10}{\ignorespaces S9: Realised parallel speedup of the 80-core sharded deployment, computed as $T^{\mathrm  {ser}}_{\mathit  {pipeline}} / T^{\mathrm  {wall}}_{\mathit  {pipeline}}$ for every (SPL, approach, coverage level) cell. The article main text (Section~\ref {sec:rq2_throughput}) reports the three industrial values for \textit  {Model Once, Generate Any} inline; this table gives the complete set.}}{7}{table.10}\protected@file@percent }
\newlabel{tab:rq2-supp-S9}{{10}{7}{S9: Realised parallel speedup of the 80-core sharded deployment, computed as $T^{\mathrm {ser}}_{\mathit {pipeline}} / T^{\mathrm {wall}}_{\mathit {pipeline}}$ for every (SPL, approach, coverage level) cell. The article main text (Section~\ref {sec:rq2_throughput}) reports the three industrial values for \textit {Model Once, Generate Any} inline; this table gives the complete set}{table.10}{}}
