\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces S7: Pairwise Wilcoxon signed-rank results on edge omission (Benjamini--Hochberg corrected, $\alpha = 0.05$). MO denotes \textit  {Model Once, Generate Any} and Struct denotes the structural baseline. The winner column reports which side of each comparison is favoured by the Vargha--Delaney $A_{12}$ value.}}{3}{table.7}\protected@file@percent }
\newlabel{tab:rq3-supp-S7}{{7}{3}{S7: Pairwise Wilcoxon signed-rank results on edge omission (Benjamini--Hochberg corrected, $\alpha = 0.05$). MO denotes \textit {Model Once, Generate Any} and Struct denotes the structural baseline. The winner column reports which side of each comparison is favoured by the Vargha--Delaney $A_{12}$ value}{table.7}{}}
\@writefile{lot}{\contentsline {table}{\numberline {8}{\ignorespaces S8: Pairwise Wilcoxon signed-rank results on event omission (Benjamini--Hochberg corrected, $\alpha = 0.05$). Same conventions as Table~\ref {tab:rq3-supp-S7}.}}{4}{table.8}\protected@file@percent }
\newlabel{tab:rq3-supp-S8}{{8}{4}{S8: Pairwise Wilcoxon signed-rank results on event omission (Benjamini--Hochberg corrected, $\alpha = 0.05$). Same conventions as Table~\ref {tab:rq3-supp-S7}}{table.8}{}}
\@writefile{lot}{\contentsline {table}{\numberline {9}{\ignorespaces S9: Per-(SPL, approach) detail of the Edge--Event paired Wilcoxon tests reported in aggregate in Table~\ref {tab:rq3-paired}. Each row corresponds to one of the $56$ SPL$\times $approach combinations: $8$ SPLs times the $7$ approaches reported in this article. Median edge / event values, paired delta (event minus edge), Benjamini--Hochberg corrected $p$-value, and Vargha--Delaney $A_{12}$ are listed for both the subsumption (mutation score) and earliness (penalized DC) tests. Approach abbreviations: MO = \textit  {Model Once, Generate Any}, Struct = structural baseline, Stoch = stochastic baseline.}}{5}{table.9}\protected@file@percent }
\newlabel{tab:rq3-supp-S9}{{9}{5}{S9: Per-(SPL, approach) detail of the Edge--Event paired Wilcoxon tests reported in aggregate in Table~\ref {tab:rq3-paired}. Each row corresponds to one of the $56$ SPL$\times $approach combinations: $8$ SPLs times the $7$ approaches reported in this article. Median edge / event values, paired delta (event minus edge), Benjamini--Hochberg corrected $p$-value, and Vargha--Delaney $A_{12}$ are listed for both the subsumption (mutation score) and earliness (penalized DC) tests. Approach abbreviations: MO = \textit {Model Once, Generate Any}, Struct = structural baseline, Stoch = stochastic baseline}{table.9}{}}
\@writefile{lot}{\contentsline {table}{\numberline {10}{\ignorespaces S10: Damping-factor sensitivity, full results. The upper sub-table reports the Friedman omnibus tests: median per-SPL value at each damping factor and the Benjamini--Hochberg adjusted $p$-value across the three settings. Cells with $p_{\mathit  {BH}} > 0.05$ are reported as n.s. The number of paired products $n$ is the count of products with all three damping settings recorded. The lower sub-table reports the post-hoc Vargha--Delaney $A_{12}$ effect sizes for the pairwise comparisons within each significant Friedman cell, with the magnitude classification (negligible / small / medium / large) used in the manuscript and the corresponding adjusted $p$-value.}}{6}{table.10}\protected@file@percent }
\newlabel{tab:rq3-supp-S10}{{10}{6}{S10: Damping-factor sensitivity, full results. The upper sub-table reports the Friedman omnibus tests: median per-SPL value at each damping factor and the Benjamini--Hochberg adjusted $p$-value across the three settings. Cells with $p_{\mathit {BH}} > 0.05$ are reported as n.s. The number of paired products $n$ is the count of products with all three damping settings recorded. The lower sub-table reports the post-hoc Vargha--Delaney $A_{12}$ effect sizes for the pairwise comparisons within each significant Friedman cell, with the magnitude classification (negligible / small / medium / large) used in the manuscript and the corresponding adjusted $p$-value}{table.10}{}}
\@writefile{lot}{\contentsline {table}{\numberline {11}{\ignorespaces S11: Multi-seed stability of the stochastic baseline across 10 seeds (RQ3$^{b}$). The coefficient-of-variation (CV) is computed per product across seeds; the table reports the per-SPL distribution summary. Bands are very\_stable (median CV $< 5\%$), stable (5--10\%), and notable\_variance ($> 10\%$).}}{7}{table.11}\protected@file@percent }
\newlabel{tab:rq3-supp-S11}{{11}{7}{S11: Multi-seed stability of the stochastic baseline across 10 seeds (RQ3$^{b}$). The coefficient-of-variation (CV) is computed per product across seeds; the table reports the per-SPL distribution summary. Bands are very\_stable (median CV $< 5\%$), stable (5--10\%), and notable\_variance ($> 10\%$)}{table.11}{}}
\@writefile{lot}{\contentsline {table}{\numberline {12}{\ignorespaces S12: RQ3$^{a}$ fault-detection results. Mutation score and penalized detection cost on edge and event omission for the original RQ1 Random Walk test sequences (single seed $42 + \mathit  {productID}$, damping $0.85$). Stochastic baseline rows here are single-seed medians; the corresponding manuscript tables (Tables~\ref {tab:rq3-ms-edge} and~\ref {tab:rq3-dc-edge}) use the multi-seed median (RQ3$^{b}$).}}{8}{table.12}\protected@file@percent }
\newlabel{tab:rq3-supp-S12}{{12}{8}{S12: RQ3$^{a}$ fault-detection results. Mutation score and penalized detection cost on edge and event omission for the original RQ1 Random Walk test sequences (single seed $42 + \mathit {productID}$, damping $0.85$). Stochastic baseline rows here are single-seed medians; the corresponding manuscript tables (Tables~\ref {tab:rq3-ms-edge} and~\ref {tab:rq3-dc-edge}) use the multi-seed median (RQ3$^{b}$)}{table.12}{}}
