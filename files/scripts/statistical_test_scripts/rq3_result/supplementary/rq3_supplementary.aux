\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces S5: Median \emph  {unpenalized} percent of suite to detect on edge omission mutants (\%). Computed only over mutants the suite kills and excludes failures from the average. Compare with Table~\ref {tab:rq3-supp-S3}: the two coincide wherever the mutation score reaches $100\%$, but the unpenalized variant is much lower for the structural baseline on eMail, syngo.via, and Hockerty Shirts because it discards the unkilled mutants from the average.}}{2}{table.5}\protected@file@percent }
\newlabel{tab:rq3-supp-S5}{{5}{2}{S5: Median \emph {unpenalized} percent of suite to detect on edge omission mutants (\%). Computed only over mutants the suite kills and excludes failures from the average. Compare with Table~\ref {tab:rq3-supp-S3}: the two coincide wherever the mutation score reaches $100\%$, but the unpenalized variant is much lower for the structural baseline on eMail, syngo.via, and Hockerty Shirts because it discards the unkilled mutants from the average}{table.5}{}}
