\newlabel{sec:supp_rq1}{{}{1}{S-RQ1. Supplementary Material for RQ1 (Generation and Execution Efficiency)}{section*.1}{}}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces S1: Pooled Spearman rank correlation $\rho $ between per-product edge count and each component of $T_{\mathit  {gen}}$ for \textit  {Model Once, Generate Any}, computed across all $4{,}455$ products. The increase in component-level $\rho $ with $L$ explains the increase in the overall $\rho $ reported for \textit  {Model Once, Generate Any} in Section~\ref {sec:rq1_scaling}.}}{1}{table.1}\protected@file@percent }
\newlabel{tab:rq1-supp-S1}{{1}{1}{S1: Pooled Spearman rank correlation $\rho $ between per-product edge count and each component of $T_{\mathit {gen}}$ for \textit {Model Once, Generate Any}, computed across all $4{,}455$ products. The increase in component-level $\rho $ with $L$ explains the increase in the overall $\rho $ reported for \textit {Model Once, Generate Any} in Section~\ref {sec:rq1_scaling}}{table.1}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces S2: Median and IQR of the share of the $L$-sequence transformation in $T_{\mathit  {gen}}$ for \textit  {Model Once, Generate Any}, computed across all $4{,}455$ products.}}{1}{table.2}\protected@file@percent }
\newlabel{tab:rq1-supp-S2}{{2}{1}{S2: Median and IQR of the share of the $L$-sequence transformation in $T_{\mathit {gen}}$ for \textit {Model Once, Generate Any}, computed across all $4{,}455$ products}{table.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces S3: Per-SPL Spearman rank correlation $\rho $ between per-product edge count and per-product median $T_{\mathit  {gen}}$, for every (approach, $L$) combination. The pooled values reported in Section~\ref {sec:rq1_scaling} aggregate these per-SPL correlations and are dominated by between-SPL variation in model size.}}{2}{table.3}\protected@file@percent }
\newlabel{tab:rq1-supp-S3}{{3}{2}{S3: Per-SPL Spearman rank correlation $\rho $ between per-product edge count and per-product median $T_{\mathit {gen}}$, for every (approach, $L$) combination. The pooled values reported in Section~\ref {sec:rq1_scaling} aggregate these per-SPL correlations and are dominated by between-SPL variation in model size}{table.3}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces S4: Per-SPL median peak heap memory (MB) during test generation, per (approach, $L$) combination. Selected values are cited inline in Section~\ref {sec:rq1_exec_memory}.}}{2}{table.4}\protected@file@percent }
\newlabel{tab:rq1-supp-S4}{{4}{2}{S4: Per-SPL median peak heap memory (MB) during test generation, per (approach, $L$) combination. Selected values are cited inline in Section~\ref {sec:rq1_exec_memory}}{table.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces S5: Per-SPL median test execution time $T_{\mathit  {exec}}$ (ms), per (approach, $L$) combination. Across the board, $T_{\mathit  {exec}}$ is small relative to $T_{\mathit  {gen}}$ (Section~\ref {sec:rq1_exec_memory}).}}{2}{table.5}\protected@file@percent }
\newlabel{tab:rq1-supp-S5}{{5}{2}{S5: Per-SPL median test execution time $T_{\mathit {exec}}$ (ms), per (approach, $L$) combination. Across the board, $T_{\mathit {exec}}$ is small relative to $T_{\mathit {gen}}$ (Section~\ref {sec:rq1_exec_memory})}{table.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces S6: Run-to-run stability of $T_{\mathit  {gen}}$ across the eleven repetitions of each (SPL, approach, $L$) cell. Median, min, max, coefficient of variation $\mathrm  {CV}\% = 100 \cdot s/\bar  {x}$, and the relative interquartile range $\mathrm  {IQR}\% = 100 \cdot (Q_{3} - Q_{1}) / \text  {median}$ are reported for each cell. Section~\ref {sec:rq1_stability} summarises these distributions.}}{3}{table.6}\protected@file@percent }
\newlabel{tab:rq1-supp-S6}{{6}{3}{S6: Run-to-run stability of $T_{\mathit {gen}}$ across the eleven repetitions of each (SPL, approach, $L$) cell. Median, min, max, coefficient of variation $\mathrm {CV}\% = 100 \cdot s/\bar {x}$, and the relative interquartile range $\mathrm {IQR}\% = 100 \cdot (Q_{3} - Q_{1}) / \text {median}$ are reported for each cell. Section~\ref {sec:rq1_stability} summarises these distributions}{table.6}{}}
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces S7: JVM warm-up evidence per (SPL, approach, $L$) cell. The $\mathrm  {Mean}/\mathrm  {Median}$ and $\mathrm  {Max}/\mathrm  {Median}$ ratios across the eleven repetitions isolate cells in which a single high outlier inflates the mean while leaving the median and IQR almost unchanged. Cells with high $\mathrm  {CV}\%$ but low $\mathrm  {IQR}\%$ correspond to the warm-up fingerprint discussed in Section~\ref {sec:rq1_stability} and in the construct-validity threat in Section~\ref {sec:threats}.}}{4}{table.7}\protected@file@percent }
\newlabel{tab:rq1-supp-S7}{{7}{4}{S7: JVM warm-up evidence per (SPL, approach, $L$) cell. The $\mathrm {Mean}/\mathrm {Median}$ and $\mathrm {Max}/\mathrm {Median}$ ratios across the eleven repetitions isolate cells in which a single high outlier inflates the mean while leaving the median and IQR almost unchanged. Cells with high $\mathrm {CV}\%$ but low $\mathrm {IQR}\%$ correspond to the warm-up fingerprint discussed in Section~\ref {sec:rq1_stability} and in the construct-validity threat in Section~\ref {sec:threats}}{table.7}{}}
\@writefile{lot}{\contentsline {table}{\numberline {8}{\ignorespaces S8: Pairwise Wilcoxon signed-rank results, Vargha--Delaney $A_{12}$ effect sizes, and Benjamini--Hochberg corrected $p$-values for every metric and (SPL, $L$) combination. Approach pairs MO~vs~Struct and MO~vs~Stoch back the cross-approach claims in Section~\ref {sec:rq1_speedup}.}}{5}{table.8}\protected@file@percent }
\newlabel{tab:rq1-supp-S8}{{8}{5}{S8: Pairwise Wilcoxon signed-rank results, Vargha--Delaney $A_{12}$ effect sizes, and Benjamini--Hochberg corrected $p$-values for every metric and (SPL, $L$) combination. Approach pairs MO~vs~Struct and MO~vs~Stoch back the cross-approach claims in Section~\ref {sec:rq1_speedup}}{table.8}{}}
\@writefile{lot}{\contentsline {table}{\numberline {9}{\ignorespaces S9: Per-SPL edge-count distribution. The range ratio $\max / \min $ quantifies the within-SPL variation in product complexity. Section~\ref {sec:rq1_scaling} relates this range to the per-SPL correlation: SPLs with a narrower edge range (e.g., Bank Account, $3.3\times $) typically produce weak per-SPL correlations, while SPLs with a wider range produce sharper trends.}}{6}{table.9}\protected@file@percent }
\newlabel{tab:rq1-supp-S9}{{9}{6}{S9: Per-SPL edge-count distribution. The range ratio $\max / \min $ quantifies the within-SPL variation in product complexity. Section~\ref {sec:rq1_scaling} relates this range to the per-SPL correlation: SPLs with a narrower edge range (e.g., Bank Account, $3.3\times $) typically produce weak per-SPL correlations, while SPLs with a wider range produce sharper trends}{table.9}{}}
